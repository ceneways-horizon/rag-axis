# RAG Axis Server Configuration
# Copy this file to .env and fill in your values

# Database URL (SQLite default, use postgresql+psycopg://user:pass@host/db for PostgreSQL)
RAGAXIS_DATABASE_URL=sqlite:///./rag-axis.db

# Server settings
RAGAXIS_HOST=0.0.0.0
RAGAXIS_PORT=8000
RAGAXIS_DEBUG=false

# CORS origins (comma-separated list, only used when debug=false)
RAGAXIS_CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
